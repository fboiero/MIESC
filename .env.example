# MIESC - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for GPTScan and AIAgent)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (for future Claude integration)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: HuggingFace API Key (for SmartLLM local models)
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: Model Configuration
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.1
# OPENAI_MAX_TOKENS=1200

# Optional: MCP Configuration
# MCP_LOG_LEVEL=INFO
# MCP_MESSAGE_HISTORY_LIMIT=1000

# Note: Never commit .env file to Git (already in .gitignore)
