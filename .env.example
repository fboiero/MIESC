# MIESC Environment Configuration
# Copy to .env and customize locally. Do not commit real secrets.

# =============================================================================
# Core Settings
# =============================================================================

MIESC_DEBUG=false
MIESC_LOG_LEVEL=INFO
MIESC_LOG_FORMAT=console
# MIESC_LOG_FILE=logs/miesc.log
# MIESC_CONFIG=config/miesc.yaml
# MIESC_HOME=~/.miesc
# MIESC_OUTPUT_DIR=./output
# MIESC_CACHE_DIR=./.miesc_cache

# =============================================================================
# Local LLMs (Ollama)
# =============================================================================

OLLAMA_HOST=http://localhost:11434
MIESC_LLM_MODEL=deepseek-coder
# OLLAMA_MODEL=deepseek-coder:6.7b

# Docker on macOS:
# OLLAMA_HOST=http://host.docker.internal:11434

# =============================================================================
# Cloud LLMs (Optional)
# =============================================================================

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Formal Verification and Chain Services (Optional)
# =============================================================================

# CERTORA_KEY=...
# ETHERSCAN_API_KEY=...
# MAINNET_RPC_URL=https://...
# SEPOLIA_RPC_URL=https://...

# =============================================================================
# API / Server
# =============================================================================

MIESC_API_HOST=0.0.0.0
MIESC_API_PORT=8000
# MIESC_SECRET_KEY=change-me-for-production
# MIESC_ADMIN_API_KEY=change-me-for-production
# MIESC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# WebSocket API
MIESC_WEBSOCKET_AUTH_REQUIRED=false
# MIESC_WEBSOCKET_TOKEN=change-me-for-production
# MIESC_WS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# =============================================================================
# Tool Runtime
# =============================================================================

MIESC_TOOL_TIMEOUT=300
MIESC_MAX_FILE_SIZE=10
# SOLC_VERSION=0.8.20
# SOLC_BINARY=/usr/local/bin/solc
# MIESC_ON_COMPILE=false
# MIESC_FAIL_ON=high
# MIESC_CONTRACTS=./src

# =============================================================================
# RAG / Persistence
# =============================================================================

MIESC_DISABLE_RAG=0
MIESC_CHROMADB_DIR=~/.miesc/chromadb
MIESC_EMBEDDING_MODEL=all-MiniLM-L6-v2
# DATABASE_URL=sqlite:///./miesc.db

# =============================================================================
# Development / Reproducibility
# =============================================================================

MIESC_TELEMETRY_DISABLED=true
MIESC_SEED=1337
MIESC_LLM_PROVIDER=ollama
# MIESC_FEEDBACK_DIR=~/.miesc/feedback
# MIESC_INVARIANT_CACHE_DIR=~/.miesc/invariants
# DOCKER_DEFAULT_PLATFORM=linux/amd64
